# .env.example — CleanApp Agent001
# Copy to .env and fill in real values

# Moltbook API key (get from registration)
MOLTBOOK_API_KEY=moltbook_xxx

# Google Gemini API key (for response generation)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_FALLBACK_MODEL=gemini-2.5-pro
# none | light | high
GEMINI_REASONING_PROFILE=light
# Optional explicit override. Leave unset to use the profile mapping.
# GEMINI_THINKING_BUDGET=4096

# Agent mode
DRY_RUN=true
LOG_LEVEL=INFO

# Rate limits (self-imposed, well below platform limits)
MAX_POSTS_PER_DAY=3
MAX_COMMENTS_PER_DAY=5
RELEVANCE_THRESHOLD=0.6

# Compliance
POST_COOLDOWN_MINUTES=30
MAX_OUTREACH_PER_DAY=2
OUTREACH_COOLDOWN_DAYS=7

# Data directory for memory DB
DATA_DIR=./data
